# One of these auth paths is required — see server README.

# Option A: GitHub Copilot subscription auth (recommended for MVP)
# The account behind this token needs an active Copilot subscription
# (Free tier works but has limited monthly usage).
# Generate via: copilot cli login   OR   a fine-grained PAT with Copilot access.
# This value is passed to the SDK as its `gitHubToken` option (see evaluate.js).
COPILOT_GITHUB_TOKEN=

# Option B: logged-in user — leave COPILOT_GITHUB_TOKEN blank and the SDK falls
# back to your machine's stored Copilot/gh auth (run `copilot` once to log in).
#
# Note: full BYOK (your own OpenAI/Anthropic key via a custom provider) is NOT
# wired up in this MVP — it needs extra SDK provider config. See
# https://github.com/github/copilot-sdk/blob/main/docs/auth/byok.md

# Which model to request from Copilot (must be one Copilot exposes to your account)
COPILOT_MODEL=gpt-5

# CORS: set to your GitHub Pages origin in production, e.g. https://yourname.github.io
ALLOWED_ORIGIN=*

PORT=3000
